{
  "name": "@maxcash/frontend",
  "version": "1.0.0",
  "description": "Cloudflare Pages frontend for MaxCash loan management system",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler pages deploy dist",
    "deploy:staging": "pnpm build && wrangler pages deploy dist --project-name=maxcash-staging",
    "deploy:prod": "pnpm build && wrangler pages deploy dist --project-name=maxcash",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@maxcash/shared": "workspace:*",
    "@tanstack/react-query": "^5.12.0",
    "axios": "^1.6.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.0",
    "react-router-dom": "^6.20.0",
    "react-toastify": "^9.1.3",
    "recharts": "^2.10.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "^5.101.1",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vitest": "^1.0.0",
    "wrangler": "^3.22.4"
  }
}
