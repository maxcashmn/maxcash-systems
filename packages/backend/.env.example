# ============================================
# MAXCASH BACKEND - ENVIRONMENT VARIABLES
# ============================================

# ---------- Database (Neon Serverless PostgreSQL) ----------
# Required: Your Neon connection string
# Get from: Neon Dashboard → Connect → Connection string
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx.aws.neon.tech/neondb?sslmode=require

# Database pool settings (optional)
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000

# ---------- Authentication (JWT) ----------
# Required: Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Required: Generate with: openssl rand -base64 32
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars

# Optional: Token expiration times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Email (EmailJS) ----------
# Required: Get from EmailJS Dashboard
EMAILJS_SERVICE_ID=service_60tak0n
EMAILJS_TEMPLATE_ID=2rf8015
EMAILJS_PUBLIC_KEY=evgrpbIpwC74ge0HQ
EMAILJS_PRIVATE_KEY=your-private-key

# Optional: Email sender settings
EMAIL_FROM=noreply@maxcash.com
EMAIL_FROM_NAME=MaxCash Team

# ---------- WhatsApp Business API ----------
# Required: Get from Meta Developer Dashboard
WHATSAPP_PHONE_NUMBER_ID=1230334500152790
WHATSAPP_ACCESS_TOKEN=EAATXZBCnw6NcBRqIaE4SZA1NBpu65DwU363GCBVUZAYAjtwpZCZC9ebetUTSU9xrzpZCozI84mummwMr3xYlEQxtb14GRcH5o9pduued4IZAaLYkIIgPkhf7e6rewhytXQ07yC7W28KQwbIKZAcJto3rJYW3PXUCZB7XJpl4lbfwPhjR1uMZBJ2772YYB5yp9nVZBK8NiZBB4TgANAMDucwczxcY8P9SbjjHJbpxMm6r5ZAvhdnDG7COrqx0dgI957F9tiP93xClUeH7Ydj9w3zsm0PAk
WHATSAPP_BUSINESS_ACCOUNT_ID=1906525296700630

# ---------- Sanity CMS ----------
# Required: Get from Sanity Dashboard
SANITY_PROJECT_ID=apddfs50
SANITY_DATASET=production
SANITY_API_TOKEN=sk...

# ---------- Cloudflare ----------
# Required: Get from Cloudflare Dashboard
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ACCOUNT_ID=a9bb12885c12795f4a96a69e0a1e863d

# ---------- Application ----------
# Environment: development | staging | production
NODE_ENV=development

# Optional: Server port (default: 8787)
PORT=8787

# Optional: CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Frontend URL for email links
FRONTEND_URL=http://localhost:5173

# ---------- Payment Gateway (Future) ----------
# Optional: Payment provider credentials
PAYMENT_API_KEY=your-payment-api-key
PAYMENT_BASE_URL=https://api.payment-gateway.com

# ============================================
# HOW TO GET EACH VALUE
# ============================================
# 
# DATABASE_URL          → Neon Dashboard → Connect → Connection string
# JWT_SECRET            → Run: openssl rand -base64 32
# JWT_REFRESH_SECRET    → Run: openssl rand -base64 32
# EMAILJS_*             → EmailJS Dashboard → Account → API Keys
# WHATSAPP_*            → Meta Developer Dashboard → WhatsApp → API Setup
# SANITY_*              → Sanity Dashboard → API → Tokens
# CLOUDFLARE_*          → Cloudflare Dashboard → Profile → API Tokens
# 
# ============================================
