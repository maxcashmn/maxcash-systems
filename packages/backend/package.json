{
  "name": "@maxcash/backend",
  "version": "1.0.0",
  "description": "Cloudflare Workers backend for MaxCash loan management system",
  "main": "dist/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@maxcash/shared": "workspace:*",
    "@neondatabase/serverless": "^0.9.0",
    "hono": "^3.12.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.2.0",
    "emailjs": "^4.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240129.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0",
    "wrangler": "^3.22.4"
  }
}
